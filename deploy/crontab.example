# a-share-hot-consensus — 复制到 crontab -e（路径按机器修改）
# Python 需已安装 requirements.txt（示例：/root/miniconda3/bin/python3）
#
# 每日两次：9:25「早盘龙头预案」+ 12:30「热门龙头情报」（午休中、下午开盘前，与 monitor 触发逻辑一致）

# 9:25 集合竞价后：早盘龙头预案（auction_morning.py）
25 9 * * 1-5 /bin/bash /root/code/a-share-hot-consensus/deploy/run_hot_consensus_trading_day.sh >> /root/code/a-share-hot-consensus/cron_trading.log 2>&1

# 12:30 下午开盘前：热门龙头情报（monitor.py --scheduled，见代码内触发说明）
30 12 * * 1-5 /bin/bash /root/code/a-share-hot-consensus/deploy/run_hot_consensus_scheduled.sh >> /root/code/a-share-hot-consensus/cron_trading.log 2>&1

# 盘中常驻轮询（与上二者二选一；若只要每日两次则不要启用）
# 25 9 * * 1-5 nohup /root/miniconda3/bin/python3 /root/code/a-share-hot-consensus/monitor.py --loop >>/root/code/a-share-hot-consensus/monitor_nohup.log 2>&1
