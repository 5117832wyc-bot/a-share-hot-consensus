# 企业微信机器人；可与 ab-stock-quant 共用
WECHAT_WEBHOOK=
# 若设置则优先（情报与 AB 分流）
HC_WECHAT_WEBHOOK=

HC_POLL_INTERVAL_SEC=90
HC_MIN_PUSH_INTERVAL_SEC=300
# 有新电报时的最小推送间隔（秒）
HC_MIN_PUSH_ON_CLS_SEC=120
HC_TOP_N=15
HC_CLS_KEY_ONLY=0
# 参与 AI 的近期电报标题条数（脉络）
HC_CLS_RECENT_FOR_AI=22
# 企业微信 markdown 最大长度
HC_MARKDOWN_MAX=3600

HC_DEEPSEEK_ENABLE=0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
HC_DEEPSEEK_MAX_TOKENS=3500
