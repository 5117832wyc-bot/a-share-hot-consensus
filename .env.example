# 企业微信
WECHAT_WEBHOOK=
HC_WECHAT_WEBHOOK=

# 沪深交易日历（AkShare 新浪）；=1 时关闭日历、仅按周一至周五（旧行为）
# HC_TRADING_CAL_DISABLE=0
# 自定义交易日缓存 JSON 路径（默认：项目根 .cache/cn_sse_trade_dates.json）
# HC_TRADING_CAL_CACHE=

# 与 AB 盘中对齐（秒）
HC_POLL_INTERVAL_SEC=45

HC_MIN_PUSH_INTERVAL_SEC=300
HC_MIN_PUSH_ON_CLS_SEC=120
HC_TOP_N=15

# 财联社：仅「重要」电报可触发推送（0=任意新电报也可触发，易刷屏）
HC_CLS_IMPORTANT_ONLY=1
# 逗号分隔关键词；留空用内置默认
# HC_CLS_KEYWORDS=
HC_CLS_GATE_DISABLE=0
HC_CLS_KEY_ONLY=0

HC_CLS_CORPUS_ITEMS=45
HC_CLS_TITLE_MAX=220
HC_CLS_CONTENT_MAX=160

# 概念板块强弱（领头羊线索）
HC_SECTOR_ENABLE=1
HC_SECTOR_TOP_N=8

HC_WECHAT_MD_MAX_BYTES=4000
HC_WECHAT_CHUNK_DELAY_SEC=0.55

HC_DEEPSEEK_ENABLE=0
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
HC_DEEPSEEK_MAX_TOKENS=3200

# 早盘脚本 auction_morning.py
HC_AUCTION_MIN_INTERVAL_SEC=600
HC_AUCTION_SLOT=auto
# HC_AUCTION_SLOT=any
HC_AUCTION_CLS_KEY_ONLY=1
